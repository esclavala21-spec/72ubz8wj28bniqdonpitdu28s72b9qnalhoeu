<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MotorMusic: Pro Edition</title>
    <style>
        :root { --primary: #ff4081; --accent: #00e5ff; --bg: #0a0a0a; }
        * { box-sizing: border-box; }
        
        body { 
            margin: 0; 
            font-family: 'Segoe UI', sans-serif; 
            background: var(--bg); 
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: white; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            transition: background 0.5s ease;
            overflow: hidden;
        }
        
        .player-card {
            background: rgba(15, 15, 15, 0.9);
            backdrop-filter: blur(15px);
            padding: 25px;
            border-radius: 30px;
            width: 360px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
            border: 1px solid rgba(255,255,255,0.1);
            text-align: center;
            z-index: 5;
        }

        #mascotGif { max-height: 100px; border-radius: 15px; margin-bottom: 10px; display: none; }

        .track-title { 
            font-size: 1.1rem; color: var(--accent); font-weight: bold; 
            margin-bottom: 20px; height: 1.4em; overflow: hidden; 
            text-overflow: ellipsis; white-space: nowrap; 
        }
        
        .controls { display: flex; justify-content: center; gap: 15px; align-items: center; margin-bottom: 20px; }
        .play-btn { background: var(--primary); width: 60px; height: 60px; border-radius: 50%; border: none; color: white; font-size: 1.6rem; cursor: pointer; transition: 0.2s; }
        .play-btn:hover { transform: scale(1.1); }
        .sub-btn { background: none; border: none; color: white; font-size: 1.3rem; cursor: pointer; opacity: 0.8; }

        .playlist { 
            height: 180px; overflow-y: auto; background: rgba(255,255,255,0.03); 
            border-radius: 15px; padding: 10px; margin-bottom: 15px; 
            text-align: left; scrollbar-width: thin; 
        }
        .song-item { 
            display: flex; justify-content: space-between; align-items: center;
            padding: 8px 12px; font-size: 0.8rem; border-radius: 8px; 
            cursor: pointer; margin-bottom: 4px; 
            transition: 0.2s; border: 1px solid transparent;
        }
        .song-item:hover { background: rgba(255,255,255,0.08); }
        .song-item.active { background: rgba(0, 229, 255, 0.15); border-color: var(--accent); color: var(--accent); font-weight: bold; }

        .footer-tools { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
        .tool-group { position: relative; }
        .tool-btn { 
            background: rgba(255,255,255,0.1); border: none; color: white; 
            padding: 12px; border-radius: 12px; font-size: 0.7rem; 
            font-weight: bold; cursor: pointer; text-align: center; width: 100%; display: block;
        }
        .folder-main { background: var(--accent); color: black; grid-column: span 2; }
        
        .btn-del {
            position: absolute; top: -5px; right: -5px;
            background: #ff4081; color: white; border: none;
            border-radius: 50%; width: 22px; height: 22px;
            font-size: 0.7rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.5); z-index: 10;
        }

        /* Monitor de Memoria */
        .mem-toggle {
            margin-top: 15px; width: 100%; background: none; border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px; color: rgba(255,255,255,0.4); font-size: 0.6rem;
            cursor: pointer; padding: 5px;
        }
        .mem-panel {
            display: none; margin-top: 10px; background: rgba(0,0,0,0.8);
            border-radius: 12px; padding: 10px; text-align: left; font-size: 0.65rem;
        }
        .mem-panel.open { display: block; }
        .mem-row { display: flex; justify-content: space-between; margin-bottom: 4px; }
        .mem-bar-wrap { height: 4px; background: #333; border-radius: 2px; margin: 5px 0; overflow: hidden; }
        .mem-bar { height: 100%; background: var(--accent); transition: 0.3s; }

        input[type="file"] { display: none; }
    </style>
</head>
<body id="bgBody">

<div class="player-card">
    <img id="mascotGif" src="" alt="Mascota">
    <div class="track-title" id="displayTitle">MotorMusic 📂</div>
    
    <audio id="audioMain"></audio>

    <div class="controls">
        <button class="sub-btn" id="favBtn" onclick="toggleFavCurrent()">🤍</button>
        <button class="sub-btn" onclick="skip(-1)">⏮</button>
        <button class="play-btn" id="btnPlay" onclick="toggle()">▶</button>
        <button class="sub-btn" onclick="skip(1)">⏭</button>
    </div>

    <div class="playlist" id="uiList"></div>

    <div class="footer-tools">
        <button class="tool-btn folder-main" onclick="selectFolder()">🔗 VINCULAR CARPETA</button>
        
        <div class="tool-group">
            <button class="btn-del" onclick="removeVisual('bg')">✕</button>
            <label class="tool-btn">🖼️ FONDO <input type="file" accept="image/*" onchange="updateVisual(event, 'bg')"></label>
        </div>
        
        <div class="tool-group">
            <button class="btn-del" onclick="removeVisual('gif')">✕</button>
            <label class="tool-btn">👾 GIF <input type="file" accept="image/gif" onchange="updateVisual(event, 'gif')"></label>
        </div>
    </div>

    <button class="mem-toggle" onclick="toggleMemPanel()">🧠 MONITOR DE MEMORIA</button>
    <div class="mem-panel" id="memPanel">
        <div class="mem-row"><span>Heap Usado:</span> <span id="memUsed">—</span></div>
        <div class="mem-bar-wrap"><div class="mem-bar" id="memBar"></div></div>
        <div class="mem-row"><span>Blobs Activos:</span> <span id="memBlobs">0</span></div>
    </div>

    <div id="status" style="font-size: 0.6rem; opacity: 0.4; margin-top: 10px;"></div>
</div>

<script>
    let songHandles = [];
    let favorites = new Set();
    let currentIndex = -1;
    let currentPlayingName = "";
    let db;
    let lastBgUrl = null;
    let lastGifUrl = null;

    const audio = document.getElementById('audioMain');
    const uiList = document.getElementById('uiList');
    const displayTitle = document.getElementById('displayTitle');
    const btnPlay = document.getElementById('btnPlay');
    const mascotImg = document.getElementById('mascotGif');

    // 1. Base de datos con soporte para Blobs
    const req = indexedDB.open("MotorMusicProDB", 3);
    req.onupgradeneeded = (e) => {
        const d = e.target.result;
        if(!d.objectStoreNames.contains("settings")) d.createObjectStore("settings");
        if(!d.objectStoreNames.contains("favs")) d.createObjectStore("favs");
    };

    req.onsuccess = (e) => {
        db = e.target.result;
        loadSettings();
        autoLoadFolder();
    };

    // 2. Gestión de Carpeta
    async function selectFolder() {
        try {
            const handle = await window.showDirectoryPicker();
            await db.transaction("settings", "readwrite").objectStore("settings").put(handle, "folderHandle");
            loadFiles(handle);
        } catch (err) { console.log("Selección cancelada"); }
    }

    async function autoLoadFolder() {
        const tx = db.transaction(["settings", "favs"], "readonly");
        const getHandle = tx.objectStore("settings").get("folderHandle");
        const getFavs = tx.objectStore("favs").getAllKeys();

        getFavs.onsuccess = () => { favorites = new Set(getFavs.result); };
        getHandle.onsuccess = async () => {
            const handle = getHandle.result;
            if (handle && await handle.queryPermission() === 'granted') loadFiles(handle);
        };
    }

    async function loadFiles(dirHandle) {
        songHandles = [];
        for await (const entry of dirHandle.values()) {
            if (entry.kind === 'file' && entry.name.match(/\.(mp3|wav|ogg|m4a)$/i)) songHandles.push(entry);
        }
        sortAndRender();
        document.getElementById('status').textContent = "Carpeta vinculada: " + dirHandle.name;
    }

    function sortAndRender() {
        songHandles.sort((a, b) => {
            const aFav = favorites.has(a.name);
            const bFav = favorites.has(b.name);
            if (aFav && !bFav) return -1;
            if (!aFav && bFav) return 1;
            return a.name.localeCompare(b.name);
        });
        if (currentPlayingName !== "") currentIndex = songHandles.findIndex(h => h.name === currentPlayingName);
        renderList();
    }

    function renderList() {
        uiList.innerHTML = '';
        songHandles.forEach((h, i) => {
            const div = document.createElement('div');
            div.className = `song-item ${i === currentIndex ? 'active' : ''}`;
            div.innerHTML = `<span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${h.name}</span> <span>${favorites.has(h.name) ? "❤️" : ""}</span>`;
            div.onclick = () => playIndex(i);
            uiList.appendChild(div);
        });
    }

    // 3. Reproducción y Pantalla de Bloqueo
    async function playIndex(i) {
        if (i < 0 || i >= songHandles.length) return;
        currentIndex = i;
        currentPlayingName = songHandles[i].name;

        const file = await songHandles[i].getFile();
        
        // LIMPIEZA DE RAM (Revocar URL anterior)
        if (audio.src) URL.revokeObjectURL(audio.src);
        audio.src = URL.createObjectURL(file);
        audio.play();

        const cleanTitle = currentPlayingName.replace(/\.[^/.]+$/, "");
        displayTitle.textContent = cleanTitle;
        btnPlay.textContent = '⏸';

        // METADATOS PARA PANTALLA DE BLOQUEO
        if ('mediaSession' in navigator) {
            navigator.mediaSession.metadata = new MediaMetadata({
                title: cleanTitle,
                artist: "MotorMusic Pro",
                artwork: [{ src: 'https://cdn-icons-png.flaticon.com/512/3844/3844724.png', sizes: '512x512', type: 'image/png' }]
            });
            navigator.mediaSession.setActionHandler('previoustrack', () => skip(-1));
            navigator.mediaSession.setActionHandler('nexttrack', () => skip(1));
        }

        updateFavBtn();
        renderList();
    }

    // 4. Personalización (Fondo y GIF)
    async function updateVisual(e, type) {
        const file = e.target.files[0];
        if (!file) return;
        // Guardar como Blob directamente (más eficiente que Base64)
        await db.transaction("settings", "readwrite").objectStore("settings").put(file, type + "Blob");
        loadVisuals();
    }

    async function removeVisual(type) {
        const tx = db.transaction("settings", "readwrite");
        tx.objectStore("settings").delete(type + "Blob");
        tx.oncomplete = () => {
            if (type === 'bg') {
                document.body.style.backgroundImage = "none";
                if (lastBgUrl) URL.revokeObjectURL(lastBgUrl);
            } else {
                mascotImg.style.display = "none";
                if (lastGifUrl) URL.revokeObjectURL(lastGifUrl);
            }
            document.getElementById('status').textContent = `Elemento ${type} eliminado.`;
        };
    }

    function loadSettings() { loadVisuals(); }

    function loadVisuals() {
        const os = db.transaction("settings", "readonly").objectStore("settings");
        
        os.get("bgBlob").onsuccess = (e) => {
            if (e.target.result) {
                if (lastBgUrl) URL.revokeObjectURL(lastBgUrl);
                lastBgUrl = URL.createObjectURL(e.target.result);
                document.body.style.backgroundImage = `url(${lastBgUrl})`;
            }
        };

        os.get("gifBlob").onsuccess = (e) => {
            if (e.target.result) {
                if (lastGifUrl) URL.revokeObjectURL(lastGifUrl);
                lastGifUrl = URL.createObjectURL(e.target.result);
                mascotImg.src = lastGifUrl;
                mascotImg.style.display = "inline-block";
            }
        };
    }

    // 5. Utilidades
    function toggleFavCurrent() {
        if (currentIndex === -1) return;
        const name = songHandles[currentIndex].name;
        const tx = db.transaction("favs", "readwrite");
        if (favorites.has(name)) {
            favorites.delete(name);
            tx.objectStore("favs").delete(name);
        } else {
            favorites.add(name);
            tx.objectStore("favs").put(true, name);
        }
        updateFavBtn();
        sortAndRender();
    }

    function updateFavBtn() {
        document.getElementById('favBtn').textContent = (currentIndex !== -1 && favorites.has(songHandles[currentIndex].name)) ? "❤️" : "🤍";
    }

    function toggle() {
        if (currentIndex === -1 && songHandles.length > 0) return playIndex(0);
        audio.paused ? (audio.play(), btnPlay.textContent='⏸') : (audio.pause(), btnPlay.textContent='▶');
    }

    function skip(dir) {
        if (songHandles.length === 0) return;
        playIndex((currentIndex + dir + songHandles.length) % songHandles.length);
    }

    audio.onended = () => skip(1);

    // 6. Monitor de Memoria Pro
    let created = 0, revoked = 0;
    const _c = URL.createObjectURL, _r = URL.revokeObjectURL;
    URL.createObjectURL = (o) => { created++; return _c(o); };
    URL.revokeObjectURL = (u) => { revoked++; _r(u); };

    function toggleMemPanel() {
        const p = document.getElementById('memPanel');
        p.classList.toggle('open');
        if (p.classList.contains('open')) setInterval(updateMem, 2000);
    }

    function updateMem() {
        if (performance.memory) {
            const used = performance.memory.usedJSHeapSize;
            const limit = performance.memory.jsHeapSizeLimit;
            document.getElementById('memUsed').textContent = (used / 1024 / 1024).toFixed(2) + " MB";
            document.getElementById('memBar').style.width = (used / limit * 100) + "%";
        }
        document.getElementById('memBlobs').textContent = (created - revoked);
    }
</script>
</body>
</html>

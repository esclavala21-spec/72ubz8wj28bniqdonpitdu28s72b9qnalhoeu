<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MotorMusic Pro</title>
    <style>
        :root {
            --bg-dark: #121212;
            --panel-dark: #1e1e1e;
            --accent-green: #1db954;
            --text-main: #ffffff;
            --text-dim: #b3b3b3;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: var(--bg-dark); color: var(--text-main); display: flex; height: 100vh; overflow: hidden; flex-direction: column; }

        /* Contenedor Principal */
        .app-container { display: flex; flex: 1; overflow: hidden; }

        /* Sidebar (25%) */
        #sidebar {
            width: 30%;
            background-color: #000;
            display: flex;
            flex-direction: column;
            border-right: 1px solid #282828;
            padding: 20px 10px;
        }

        .btn-importar {
            background-color: var(--accent-green);
            color: black;
            padding: 12px;
            border-radius: 20px;
            text-align: center;
            font-weight: bold;
            cursor: pointer;
            margin-bottom: 20px;
            display: block;
        }

        .lista-wrapper { overflow-y: auto; flex: 1; }
        h3 { font-size: 12px; text-transform: uppercase; color: var(--text-dim); margin: 15px 5px 10px; }
        
        ul { list-style: none; }
        li {
            padding: 10px;
            border-radius: 5px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            transition: 0.2s;
        }
        li:hover { background-color: #282828; }
        li.active { color: var(--accent-green); background-color: #282828; }
        .heart { color: var(--text-dim); transition: 0.3s; }
        .heart.active { color: var(--accent-green); }

        /* Panel Central (75%) */
        #stage {
            flex: 1;
            background: linear-gradient(to bottom, #222, #121212);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        #visualizer-container {
            width: 300px;
            height: 300px;
            background-color: #000;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            overflow: hidden;
            margin-bottom: 30px;
            border: 2px solid #333;
        }

        #visualGif { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }

        #info-track { text-align: center; }
        #titulo { font-size: 24px; margin-bottom: 5px; }
        #ruta { color: var(--text-dim); font-size: 12px; font-style: italic; }

        /* Footer (Controles) */
        footer {
            height: 90px;
            background-color: #181818;
            border-top: 1px solid #282828;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 10px 20px;
        }

        .progress-container { width: 100%; display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        #progress-bar { flex: 1; accent-color: var(--accent-green); cursor: pointer; }
        .time { font-size: 11px; color: var(--text-dim); width: 35px; }

        .playback-controls { display: flex; align-items: center; gap: 25px; }
        .control-btn { background: none; border: none; color: white; font-size: 24px; cursor: pointer; transition: 0.2s; }
        .control-btn:hover { transform: scale(1.1); color: var(--accent-green); }
        .play-trigger { font-size: 40px; }

        /* Mobile Adjustments */
        @media (max-width: 600px) {
            .app-container { flex-direction: column; }
            #sidebar { width: 100%; height: 40%; }
            #visualizer-container { width: 200px; height: 200px; }
        }
    </style>
</head>
<body>

    <div class="app-container">
        <aside id="sidebar">
            <label class="btn-importar">
                📁 IMPORTAR CARPETA
                <input type="file" id="inputFiles" webkitdirectory directory multiple style="display:none">
            </label>
            
            <div class="lista-wrapper">
                <h3>💚 Favoritos</h3>
                <ul id="listaFavoritos"></ul>
                <h3>🎵 Biblioteca</h3>
                <ul id="listaGeneral"></ul>
            </div>
        </aside>

        <main id="stage">
            <div id="visualizer-container">
                <img id="visualGif" src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJndnN6Yms1eXJ6eXN6Z3Z6Z3Z6Z3Z6Z3Z6Z3Z6Z3Z6Z3ZpbmNlcHRpb24mZXA9djFfaW50ZXJuYWxfZ2lmX2J5X2lkJmN0PWc/3o7TKMGpxxcaatOAHm/giphy.gif" alt="Visual">
            </div>
            <div id="info-track">
                <h2 id="titulo">Selecciona una canción</h2>
                <p id="ruta">Memoria: 0MB utilizados</p>
            </div>
        </main>
    </div>

    <footer>
        <div class="progress-container">
            <span class="time" id="currentTime">0:00</span>
            <input type="range" id="progress-bar" value="0" min="0" max="100">
            <span class="time" id="duration">0:00</span>
        </div>
        <div class="playback-controls">
            <button class="control-btn" id="btnPrev">⏮</button>
            <button class="control-btn play-trigger" id="btnPlay">▶</button>
            <button class="control-btn" id="btnNext">⏭</button>
        </div>
        <audio id="mainAudio" style="display:none"></audio>
    </footer>

    <script>
        const audio = document.getElementById('mainAudio');
        const input = document.getElementById('inputFiles');
        const listaGeneral = document.getElementById('listaGeneral');
        const listaFavoritos = document.getElementById('listaFavoritos');
        const btnPlay = document.getElementById('btnPlay');
        const progressBar = document.getElementById('progress-bar');
        
        let playlist = [];
        let currentIndex = -1;
        let currentUrl = null;

        // --- GESTIÓN DE CARPETA ---
        input.addEventListener('change', (e) => {
            const files = Array.from(e.target.files).filter(f => f.type.startsWith('audio/'));
            if (files.length === 0) return;
            
            playlist = files;
            renderPlaylist();
        });

        function renderPlaylist() {
            listaGeneral.innerHTML = '';
            playlist.forEach((file, index) => {
                const li = document.createElement('li');
                li.id = `track-${index}`;
                li.innerHTML = `
                    <span>${file.name.substring(0, 30)}...</span>
                    <span class="heart" onclick="toggleFav(event, ${index})">❤</span>
                `;
                li.onclick = () => playTrack(index);
                listaGeneral.appendChild(li);
            });
        }

        // --- MOTOR DE AUDIO (Antifugas de memoria) ---
        function playTrack(index) {
            if (index < 0 || index >= playlist.length) return;
            currentIndex = index;

            // 1. Limpieza de memoria crítica
            if (currentUrl) {
                URL.revokeObjectURL(currentUrl);
            }

            // 2. Crear nueva ruta temporal
            currentUrl = URL.createObjectURL(playlist[currentIndex]);
            audio.src = currentUrl;
            
            // 3. UI
            document.querySelectorAll('li').forEach(el => el.classList.remove('active'));
            document.getElementById(`track-${index}`).classList.add('active');
            document.getElementById('titulo').textContent = playlist[currentIndex].name;
            document.getElementById('ruta').textContent = `Local Path: /${playlist[currentIndex].name}`;
            
            audio.play();
            btnPlay.textContent = '⏸';
        }

        // --- CONTROLES ---
        btnPlay.onclick = () => {
            if (audio.paused) { audio.play(); btnPlay.textContent = '⏸'; }
            else { audio.pause(); btnPlay.textContent = '▶'; }
        };

        document.getElementById('btnNext').onclick = () => {
            let next = currentIndex + 1;
            if (next >= playlist.length) next = 0;
            playTrack(next);
        };

        document.getElementById('btnPrev').onclick = () => {
            let prev = currentIndex - 1;
            if (prev < 0) prev = playlist.length - 1;
            playTrack(prev);
        };

        // Salto automático al terminar
        audio.onended = () => document.getElementById('btnNext').click();

        // --- BARRA DE PROGRESO ---
        audio.ontimeupdate = () => {
            const pct = (audio.currentTime / audio.duration) * 100;
            progressBar.value = pct || 0;
            document.getElementById('currentTime').textContent = formatTime(audio.currentTime);
            document.getElementById('duration').textContent = formatTime(audio.duration);
        };

        progressBar.oninput = () => {
            const time = (progressBar.value / 100) * audio.duration;
            audio.currentTime = time;
        };

        function formatTime(sec) {
            if (isNaN(sec)) return "0:00";
            const m = Math.floor(sec / 60);
            const s = Math.floor(sec % 60);
            return `${m}:${s < 10 ? '0' : ''}${s}`;
        }

        // --- FAVORITOS (Lógica de orden dinámico) ---
        function toggleFav(e, index) {
            e.stopPropagation();
            const heart = e.target;
            const li = heart.parentElement;
            
            heart.classList.toggle('active');
            
            if (heart.classList.contains('active')) {
                listaFavoritos.appendChild(li); // Se mueve a la sección de arriba
            } else {
                listaGeneral.appendChild(li); // Vuelve a la biblioteca
            }
        }
    </script>
</body>
</html>
